{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      // 🚀 ADD THIS LINE TO FIX THE '@/lib/db' ERROR 🚀
      "@/*": ["./*"],
      
      "@aws-sdk/s3-request-presigner": ["node_modules/@aws-sdk/s3-request-presigner"]
    }
  },
  "include": ["server.ts", "lib/**/*.ts", "app/**/*.ts"], // 🚀 ADD LIB AND APP FOLDERS HERE
  "exclude": ["node_modules"]
}