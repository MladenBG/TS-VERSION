{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@aws-sdk/s3-request-presigner": ["node_modules/@aws-sdk/s3-request-presigner"],
      "*": ["node_modules/*"]
    }
  },
  "include": ["server.ts"],
  "exclude": ["node_modules"]
}