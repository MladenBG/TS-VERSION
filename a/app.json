{
  "expo": {
    "name": "Dateroot",
    "slug": "dateroot",
    "version": "1.0.0",
    "scheme": "dateroot",
    "android": {
      "package": "com.dateroot.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.INTERNET"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dateroot.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Dateroot needs access to your camera for video dates.",
        "NSMicrophoneUsageDescription": "Dateroot needs access to your microphone for video dates."
      }
    },
    "plugins": [
      "expo-audio"
    ],
    "newArchEnabled": false
  }
}
